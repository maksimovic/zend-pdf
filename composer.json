{
    "name": "maksimovic/zend-pdf",
    "description": "Zend Framework 1 Pdf package",
    "keywords": ["framework", "zf1", "zend", "pdf"],
    "homepage": "http://framework.zend.com/",
    "license": "BSD-3-Clause",
    "require": {
        "php": ">=8.1",
        "ext-ctype": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-zlib": "*",
        "maksimovic/zend-exception": "^2.0.1",
        "maksimovic/zend-log": "^2.0.0",
        "maksimovic/zend-memory": "^2.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-0": {
            "Zend_Pdf": "library/"
        }
    },
    "replace": {
        "zf1/zend-pdf": "^1.12",
        "zf1s/zend-pdf": "^1.12",
        "zendframework/zend-pdf": "*"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "phpstan": "phpstan analyse --memory-limit=256M"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev"
        }
    }
}
